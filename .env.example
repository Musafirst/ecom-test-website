# Public storefront
NEXT_PUBLIC_SITE_URL=https://www.jammtrade.com

# Shopify Storefront API (server-side only)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=replace_with_storefront_token
SHOPIFY_WEBHOOK_SECRET=replace_with_webhook_secret

# Supabase service role access (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional Shopify Admin maintenance callback
SHOPIFY_CLIENT_ID=replace_with_shopify_app_client_id
SHOPIFY_CLIENT_SECRET=replace_with_shopify_app_client_secret
SHOPIFY_OAUTH_STATE=replace_with_a_long_random_value
