# Public storefront
NEXT_PUBLIC_SITE_URL=https://www.jammtrade.com

# Google Analytics 4 measurement ID (public). Enables the GoogleAnalytics
# component in the root layout on every page. Leave unset to disable analytics.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional public promotion. Configure the matching Shopify discount before enabling.
# NEXT_PUBLIC_WELCOME_DISCOUNT_CODE=WELCOME20
# NEXT_PUBLIC_WELCOME_DISCOUNT_PERCENT=20

# Optional public social links. If omitted, the Next.js footer reads
# shopify-theme/config/settings_data.json social settings.
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_account
# NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@your_account
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/your_page
# NEXT_PUBLIC_X_URL=https://x.com/your_account
# NEXT_PUBLIC_YOUTUBE_URL=https://youtube.com/@your_channel

# Shopify Storefront API (server-side only)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=replace_with_storefront_token
SHOPIFY_WEBHOOK_SECRET=replace_with_webhook_secret

# Shopify Admin API token used by runtime business-info sync.
# The same token can also be used by the local sync scripts when it has read_themes.
SHOPIFY_ADMIN_TOKEN=replace_with_admin_token

# Optional: Vercel deploy hook called after Shopify shop/update webhooks.
# The footer also refreshes through /api/shopify/business-info, so this is only
# needed if you want a full site rebuild after Shopify business-info changes.
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Supabase service role access (server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Optional protected observability endpoint: GET /api/metrics
OBSERVABILITY_METRICS_TOKEN=replace_with_a_long_random_value

# Optional Shopify Admin maintenance callback
SHOPIFY_CLIENT_ID=replace_with_shopify_app_client_id
SHOPIFY_CLIENT_SECRET=replace_with_shopify_app_client_secret
SHOPIFY_OAUTH_STATE=replace_with_a_long_random_value

# Optional manual Shopify maintenance scripts. Prefer temporary tokens locally.
# SHOPIFY_THEME_ZIP=reviewed-theme-archive.zip
# PUBLISH_SHOPIFY_THEME=false
