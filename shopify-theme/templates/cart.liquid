{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}

<div class="cart-page">
  <div class="container container--narrow">

    <div class="cart-header">
      <!-- Product browsing belongs on the canonical Next.js storefront. -->
      <a href="{{ public_shop_url }}" class="cart-header__back" aria-label="Back to Jamm Trade">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ 'cart.general.continue_shopping' | t }}
      </a>
      <h1 class="cart-header__title">{{ 'cart.general.title' | t }}</h1>
    </div>

    {% if cart.item_count > 0 %}
      {% form 'cart', cart, id: 'CartForm' %}
        <div class="cart-layout">

          <!-- Line items -->
          <div class="cart-items">
            {% for item in cart.items %}
              <div class="cart-item" data-line="{{ forloop.index }}">
                <a href="{{ public_shop_url }}/product/{{ item.product.handle }}" class="cart-item__media">
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 200, height: 200, crop: 'center' }}"
                      alt="{{ item.image.alt | default: item.title | escape }}"
                      class="cart-item__img"
                      width="{{ item.image.width }}"
                      height="{{ item.image.height }}"
                      loading="lazy"
                    >
                  {% endif %}
                </a>

                <div class="cart-item__details">
                  <a href="{{ public_shop_url }}/product/{{ item.product.handle }}" class="cart-item__title">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  {% if item.vendor != blank %}
                    <p class="cart-item__vendor">{{ item.vendor }}</p>
                  {% endif %}
                  <p class="cart-item__price">{{ item.final_line_price | money }}</p>

                  <div class="cart-item__qty">
                    <div class="qty-selector qty-selector--sm">
                      <button type="button" class="qty-btn" data-line="{{ forloop.index }}" data-action="decrease" aria-label="Decrease">−</button>
                      <input
                        type="number"
                        name="updates[]"
                        value="{{ item.quantity }}"
                        min="0"
                        class="qty-input"
                        aria-label="Quantity for {{ item.title | escape }}"
                        data-line="{{ forloop.index }}"
                      >
                      <button type="button" class="qty-btn" data-line="{{ forloop.index }}" data-action="increase" aria-label="Increase">+</button>
                    </div>

                    <button
                      type="button"
                      class="cart-item__remove"
                      data-line="{{ forloop.index }}"
                      aria-label="Remove {{ item.title | escape }} from cart"
                    >
                      {{ 'cart.general.remove' | t }}
                    </button>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>

          <!-- Order summary -->
          <div class="cart-summary">
            <div class="cart-summary__inner">
              <h2 class="cart-summary__title">{{ 'cart.general.order_summary' | t }}</h2>

              <div class="cart-summary__row">
                <span>{{ 'cart.general.subtotal' | t }}</span>
                <span>{{ cart.total_price | money }}</span>
              </div>

              <p class="cart-summary__note">{{ 'cart.general.taxes_note' | t }}</p>

              <button type="submit" name="checkout" class="btn btn--primary btn--full cart-summary__checkout">
                {{ 'cart.general.checkout' | t }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>

              <a href="{{ public_shop_url }}" class="cart-summary__continue">
                ← {{ 'cart.general.continue_shopping' | t }}
              </a>
            </div>
          </div>

        </div>
      {% endform %}

    {% else %}
      <div class="cart-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" class="cart-empty__icon" aria-hidden="true">
          <path d="M6 7h13l-1.2 8.2a2 2 0 0 1-2 1.8H8.4a2 2 0 0 1-2-1.7L5 4H3" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="9" cy="20" r="1"/>
          <circle cx="17" cy="20" r="1"/>
        </svg>
        <h2 class="cart-empty__title">{{ 'cart.general.empty' | t }}</h2>
        <p class="cart-empty__sub">{{ 'cart.general.empty_sub' | t }}</p>
        <a href="{{ public_shop_url }}" class="btn btn--primary">{{ 'cart.general.browse_products' | t }}</a>
      </div>
    {% endif %}

  </div>
</div>
