{% capture shop_business_address %}
  {%- if shop.address.address1 != blank -%}{{ shop.address.address1 }}<br>{%- endif -%}
  {%- if shop.address.address2 != blank -%}{{ shop.address.address2 }}<br>{%- endif -%}
  {%- if shop.address.city != blank -%}{{ shop.address.city }}{%- endif -%}
  {%- if shop.address.province_code != blank -%}{%- if shop.address.city != blank -%}, {% endif -%}{{ shop.address.province_code }}{%- elsif shop.address.province != blank -%}{%- if shop.address.city != blank -%}, {% endif -%}{{ shop.address.province }}{%- endif -%}
  {%- if shop.address.zip != blank -%} {{ shop.address.zip }}{%- endif -%}
  {%- if shop.address.country != blank -%}<br>{{ shop.address.country }}{%- endif -%}
{% endcapture %}
{% assign shop_business_address = shop_business_address | strip %}
{% assign contact_business_address = shop_business_address | default: settings.public_location | default: 'Philadelphia, PA' %}

<section class="contact-page">
  <div class="container">
    <div class="contact-grid">

      <div class="contact-card contact-card--left">
        <p class="contact-card__eyebrow">Customer care</p>
        <h1 class="contact-card__title">Contact Jamm Trade</h1>
        <p class="contact-card__intro">For order support, product questions, shipping, returns, or policy help, reach the Jamm Trade team directly.</p>
      </div>

      <div class="contact-card contact-card--right">
        <div class="contact-info__item">
          <h2 class="contact-info__heading">Business</h2>
          <p class="contact-info__text">Jamm Trade LLC</p>
          <p class="contact-info__text contact-info__address">{{ contact_business_address }}</p>
        </div>
        <div class="contact-info__item">
          <h2 class="contact-info__heading">Email</h2>
          <a href="mailto:{{ settings.support_email | default: 'contact@jammtrade.com' }}" class="contact-info__link">{{ settings.support_email | default: 'contact@jammtrade.com' }}</a>
        </div>
        <div class="contact-info__item">
          <h2 class="contact-info__heading">Support Hours</h2>
          <p class="contact-info__text">Monday through Friday, 10:00 AM to 6:00 PM Eastern Time.</p>
        </div>
        <div class="contact-info__item">
          <h2 class="contact-info__heading">Order Help</h2>
          <p class="contact-info__text">Include your order number, product name, delivery address, and clear photos if you are contacting us about a damaged or incorrect item.</p>
        </div>
      </div>

    </div>
  </div>
</section>
