{% assign public_clothing_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop/collection/clothing' %}

<script>
  window.location.replace({{ public_clothing_url | json }});
</script>

<section class="page-template">
  <div class="container container--narrow">
    <header class="page-header">
      <p class="section-eyebrow">Category</p>
      <h1 class="page-title">Clothing</h1>
    </header>

    <div class="page-content">
      <p>Browse Jamm Trade clothing in the clothing collection.</p>
      <p><a href="{{ public_clothing_url }}">Shop Clothing</a></p>
    </div>
  </div>
</section>
