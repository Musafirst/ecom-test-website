{% assign product_is_clothing = false %}
{% assign product_title_downcase = product.title | downcase %}
{% assign product_type_downcase = product.type | downcase %}
{% assign product_tags_downcase = product.tags | join: ',' | downcase %}
{% if product_title_downcase contains 'hoodie' or product_title_downcase contains 'shirt' or product_title_downcase contains 'apparel' %}
  {% assign product_is_clothing = true %}
{% endif %}
{% if product_type_downcase contains 'clothing' or product_type_downcase contains 'apparel' %}
  {% assign product_is_clothing = true %}
{% endif %}
{% if product_tags_downcase contains 'clothing' or product_tags_downcase contains 'apparel' or product_tags_downcase contains 'hoodie' %}
  {% assign product_is_clothing = true %}
{% endif %}
{% if product.type contains 'Clothing' or product.type contains 'Apparel' %}
  {% assign product_is_clothing = true %}
{% endif %}
{% for product_collection in product.collections %}
  {% if product_collection.handle == 'clothing' or product_collection.handle == 'clothing-collection' %}
    {% assign product_is_clothing = true %}
  {% endif %}
{% endfor %}

<div class="product-page{% if product_is_clothing %} product-page--clothing{% endif %}">
  <div class="container">
    <div class="product-page__grid">

      <!-- Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__main" id="ProductGalleryMain">
          {% if product.images.size > 0 %}
            {% for image in product.images %}
              <img
                src="{{ image | image_url: width: 1000, height: 1000, crop: 'center' }}"
                alt="{{ image.alt | default: product.title | escape }}"
                class="product-gallery__img{% if forloop.first %} is-active{% endif %}"
                data-gallery-img="{{ forloop.index0 }}"
                width="{{ image.width }}"
                height="{{ image.height }}"
                loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              >
            {% endfor %}
          {% else %}
            <div class="product-gallery__placeholder">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {% endif %}
        </div>

        {% if product.images.size > 1 %}
          <div class="product-gallery__thumbs">
            {% for image in product.images %}
              <button
                type="button"
                class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                data-thumb="{{ forloop.index0 }}"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 200, height: 200, crop: 'center' }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  loading="lazy"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Purchase panel -->
      <div class="product-purchase">

        {% if product.vendor != blank %}
          <p class="product-purchase__vendor">{{ product.vendor }}</p>
        {% endif %}

        <h1 class="product-purchase__title">{{ product.title }}</h1>

        <div class="product-purchase__price">
          {% if product.compare_at_price > product.price %}
            <span class="price--compare">{{ product.compare_at_price | money }}</span>
          {% endif %}
          <span class="price--current">{{ product.price | money }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="price--badge">{{ 'products.product.sale' | t }}</span>
          {% endif %}
        </div>

        {% if product.description != blank %}
          {% assign description_plain = product.description | strip_html | replace: '&nbsp;', ' ' | strip %}
          <div class="product-purchase__desc">
            <p>{{ description_plain | truncate: 180 }}</p>
            {% if description_plain.size > 180 %}
              <details class="product-description-toggle">
                <summary>
                  <span class="product-description-toggle__more">{{ 'products.product.read_more' | t }}</span>
                  <span class="product-description-toggle__less">{{ 'products.product.show_less' | t }}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <div class="product-description-toggle__content">{{ product.description }}</div>
              </details>
            {% endif %}
          </div>
        {% endif %}

        <div class="product-purchase__rule"></div>

        {% form 'product', product, id: 'ProductForm' %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="return_to" value="">

          {% if product.variants.size > 1 %}
            <div class="product-variants">
              {% for option in product.options_with_values %}
                <div class="variant-option">
                  <label class="variant-option__label">{{ option.name }}</label>
                  <div class="variant-option__values">
                    {% for value in option.values %}
                      <button
                        type="button"
                        class="variant-btn{% if option.selected_value == value %} is-selected{% endif %}"
                        data-option="{{ option.name }}"
                        data-value="{{ value | escape }}"
                      >
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}

          <div class="product-purchase__qty-row">
            <span class="product-purchase__qty-label">{{ 'products.product.quantity' | t }}</span>
            <div class="qty-selector">
              <button type="button" class="qty-btn" data-qty="-1" aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" value="1" min="1" class="qty-input" aria-label="Quantity">
              <button type="button" class="qty-btn" data-qty="1" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <div class="product-purchase__actions">
            <button
              type="submit"
              name="add"
              class="btn btn--primary btn--full"
              {% unless product.available %}disabled{% endunless %}
            >
              {% if product.available %}
                {{ 'products.product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
          </div>

          {% if product.available %}
            <button
              type="submit"
              name="add"
              value="Buy now"
              class="btn btn--buy-now btn--full"
              data-buy-now
            >
              {{ 'products.product.buy_now' | t }}
            </button>
          {% endif %}
        {% endform %}

        <!-- Trust mini bar -->
        <div class="product-trust">
          <span>✓ Authentic &amp; verified</span>
          <span>✓ Secure checkout</span>
          <span>✓ Reliable shipping</span>
        </div>

      </div>
    </div>

    <!-- Related products -->
    {% if product.collections.first.products_count > 1 %}
      <div class="related-products">
        <div class="section-header">
          <p class="section-eyebrow">More like this</p>
          <h2 class="section-title">You might also like</h2>
        </div>
        <div class="section-rule"></div>
        <div class="product-grid product-grid--4">
          {% assign current_product = product %}
          {% for related in product.collections.first.products limit: 4 %}
            {% unless related.id == current_product.id %}
              {% render 'product-card', product: related %}
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</div>
