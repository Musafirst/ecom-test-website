{% comment %}
  Renders a product card in the redesign .product markup.
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}
{% assign card_label = product.collections.first.title | default: product.vendor %}

<article class="product reveal">
  <a class="product__media product__media--photo" href="{{ public_shop_url }}/product/{{ product.handle }}">
    {% if product.featured_image != blank %}
      <img class="product__photo" src="{{ product.featured_image | image_url: width: 800 }}"
        srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 800 }} 800w"
        sizes="(min-width:900px) 25vw, 50vw"
        alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy"
        width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'product__photo' }}
    {% endif %}
  </a>
  <div class="product__body">
    {% if card_label != blank %}<span class="product__cat">{{ card_label }}{% if product.vendor != blank and product.vendor != card_label %} &middot; {{ product.vendor }}{% endif %}</span>{% endif %}
    <h3 class="product__name"><a href="{{ public_shop_url }}/product/{{ product.handle }}">{{ product.title }}</a></h3>
    <span class="product__price">{% if product.price_varies %}From {% endif %}{{ product.price_min | money }}</span>
    <div class="product__cart">
      {% if product.available == false %}
        <button class="btn btn--dark btn--block" type="button" disabled><span>Sold Out</span></button>
      {% elsif product.variants.size > 1 %}
        {% comment %} Options must be chosen on the product page so the shown price always matches the charged variant. {% endcomment %}
        <a class="btn btn--dark btn--block" href="{{ public_shop_url }}/product/{{ product.handle }}"><span>Choose Options</span></a>
      {% else %}
        <button class="btn btn--dark btn--block" type="button" data-product-id="{{ product.selected_or_first_available_variant.id }}"><span>Add to Cart</span></button>
      {% endif %}
    </div>
  </div>
</article>
