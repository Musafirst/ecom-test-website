{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}
{% assign featured_products = section.settings.collection.products %}
{% if featured_products == blank %}
  {% assign featured_products = collections.all.products %}
{% endif %}

<section class="section" id="fragrance">
  <div class="container">
    <div class="section-head">
      <div class="head-left reveal">
        <p class="eyebrow">Curated Selection</p>
        <h2 class="section-title">Featured Products</h2>
      </div>
      <a class="link-arrow reveal" href="{{ public_shop_url }}/category/perfumes">
        View all products
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <div class="rule"></div>
    </div>

    {% comment %} Sorted by title so this grid always matches the Next.js storefront exactly. {% endcomment %}
    {% assign featured_sorted = featured_products | sort: 'title' %}
    <div class="products-grid">
      {% for product in featured_sorted limit: section.settings.products_count %}
        {% render 'product-card', product: product %}
      {% else %}
        <p class="section-sub">Products are temporarily unavailable. Please check back soon.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Featured collection"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "Number of products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
