{% assign public_storefront_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' %}
{% assign public_shop_url = public_storefront_url | append: '/shop' %}

<header class="header" id="SiteHeader" role="banner">
  <div class="container header__inner">
    <a class="brand" href="{{ public_shop_url }}" aria-label="{{ shop.name }}">
      <img class="brand__mark" src="{{ 'logo-badge.png' | asset_url }}" alt="Jamm Trade lotus emblem" width="46" height="46">
      <span class="brand__type">
        <span class="brand__name">JAMM TRADE</span>
        <span class="brand__tag">From Essentials to Enterprise</span>
      </span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <a href="{{ public_shop_url }}/category/perfumes">Fragrance</a>
      <a href="{{ public_shop_url }}#collections">Collections</a>
      <a href="{{ public_shop_url }}/category/electronics">Electronics</a>
      <a href="{{ public_shop_url }}/guides">Guides</a>
      <a href="{{ public_shop_url }}/about">About</a>
    </nav>

    <div class="header__actions">
      <a class="icon-btn" href="{{ public_shop_url }}#fragrance" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
      </a>
      <a class="icon-btn" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6h15l-1.5 9h-12z"/><circle cx="9" cy="20" r="1.4"/><circle cx="18" cy="20" r="1.4"/><path d="M6 6 5 3H2"/></svg>
        <span class="cart-count" data-cart-count style="display:none;">0</span>
      </a>
      <button class="icon-btn header__menu" aria-label="Menu" id="MobileMenuToggle" aria-expanded="false">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
      </button>
    </div>
  </div>
</header>

<div class="mobile-drawer" id="MobileDrawer" hidden>
  <div class="mobile-drawer__head">
    <span class="brand__name">JAMM TRADE</span>
    <button class="icon-btn" aria-label="Close menu" id="MobileDrawerClose">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 6l12 12M18 6 6 18" stroke-linecap="round"/></svg>
    </button>
  </div>
  <nav class="mobile-drawer__nav">
    <a href="{{ public_shop_url }}/category/perfumes">Fragrance</a>
    <a href="{{ public_shop_url }}#collections">Collections</a>
    <a href="{{ public_shop_url }}/category/electronics">Electronics</a>
    <a href="{{ public_shop_url }}/guides">Guides</a>
    <a href="{{ public_shop_url }}/about">About</a>
  </nav>
</div>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
