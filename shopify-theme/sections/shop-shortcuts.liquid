{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}

<section class="shortcuts-section">
  <div class="container">
    <div class="shortcuts-grid">
      {% for block in section.blocks %}
        {% if block.type == 'shortcut' %}
        {% assign shortcut_url = block.settings.url %}
        {% if shortcut_url == blank %}
          {% assign shortcut_handle = block.settings.label | handleize %}
          {% if shortcut_handle == 'perfumes' or shortcut_handle == 'electronics' %}
            {% assign shortcut_url = public_shop_url | append: '/category/' | append: shortcut_handle %}
          {% else %}
            {% assign shortcut_url = public_shop_url | append: '/collection/' | append: shortcut_handle %}
          {% endif %}
        {% endif %}
        <a href="{{ shortcut_url }}" class="shortcut-card" {{ block.shopify_attributes }}>
          <span class="shortcut-card__detail">{{ block.settings.detail }}</span>
          <span class="shortcut-card__label">
            <span class="shortcut-card__label-text">{{ block.settings.label }}</span>
            <span class="shortcut-card__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M7 17L17 7M9 7h8v8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </span>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop Shortcuts",
  "settings": [],
  "blocks": [
    {
      "type": "shortcut",
      "name": "Shortcut",
      "settings": [
        { "type": "text", "id": "detail", "label": "Detail / eyebrow" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Shop Shortcuts",
      "blocks": [
        { "type": "shortcut", "settings": { "detail": "Featured picks", "label": "Perfumes" } },
        { "type": "shortcut", "settings": { "detail": "5 fragrances", "label": "Oud" } },
        { "type": "shortcut", "settings": { "detail": "8 fragrances", "label": "Amber" } },
        { "type": "shortcut", "settings": { "detail": "Daily", "label": "Daily" } },
        { "type": "shortcut", "settings": { "detail": "Electronics", "label": "Electronics" } },
        { "type": "shortcut", "settings": { "detail": "Apparel", "label": "Clothing", "url": "https://www.jammtrade.com/shop/collection/clothing" } }
      ]
    }
  ]
}
{% endschema %}
