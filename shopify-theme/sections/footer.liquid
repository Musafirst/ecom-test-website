{% assign public_storefront_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' %}
{% assign public_shop_url = public_storefront_url | append: '/shop' %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-shell">
      <div class="footer-inner">

        <div class="footer-brand">
          <a href="{{ public_shop_url }}" aria-label="{{ shop.name }}" class="footer-logo-lockup">
            <img
              src="{{ 'jamm-trade-logo-badge.png' | asset_url }}"
              alt=""
              class="footer-logo-mark"
              width="1254"
              height="1254"
              loading="lazy"
              aria-hidden="true"
            >
            <span class="footer-logo-type">
              <span class="footer-logo-name">JAMM TRADE</span>
              <span class="footer-logo-tag">From Essentials to Enterprise</span>
            </span>
          </a>
          <p class="footer-tagline">
            {{ 'footer.tagline' | t }}
          </p>
          <div class="footer-contact">
            <p class="footer-contact__business">Jamm Trade LLC</p>
            <p class="footer-contact__address">Darby, Pennsylvania</p>
            <a href="mailto:{{ settings.support_email | default: 'contact@jammtrade.com' }}" class="footer-contact__link">{{ settings.support_email | default: 'contact@jammtrade.com' }}</a>
          </div>
        </div>

        <nav class="footer-link-group footer-link-group--desktop" aria-label="{{ 'navigation.shop' | t }}">
          <p class="footer-link-group__title">{{ 'navigation.shop' | t }}</p>
          <a href="{{ public_shop_url }}" class="footer-nav__link">{{ 'navigation.shop' | t }}</a>
          <a href="{{ public_shop_url }}/about" class="footer-nav__link">{{ 'navigation.about' | t }}</a>
          <a href="{{ public_shop_url }}/contact" class="footer-nav__link">{{ 'navigation.contact' | t }}</a>
        </nav>

        <nav class="footer-link-group footer-link-group--desktop" aria-label="{{ 'navigation.services' | t }}">
          <p class="footer-link-group__title">{{ 'navigation.services' | t }}</p>
          <a href="{{ public_storefront_url }}/jamm-cargo" class="footer-nav__link">Jamm Cargo</a>
          <a href="{{ public_storefront_url }}/jamm-fleet" class="footer-nav__link">Jamm Fleet</a>
        </nav>

        <nav class="footer-link-group footer-link-group--desktop" aria-label="{{ 'footer.policies' | t }}">
          <p class="footer-link-group__title">{{ 'footer.policies' | t }}</p>
          <a href="{{ public_shop_url }}/shipping-policy" class="footer-nav__link">{{ 'footer.shipping_policy' | t }}</a>
          <a href="{{ public_shop_url }}/refund-policy" class="footer-nav__link">{{ 'footer.refund_policy' | t }}</a>
          <a href="{{ public_shop_url }}/privacy-policy" class="footer-nav__link">{{ 'footer.privacy_policy' | t }}</a>
          <a href="{{ public_shop_url }}/terms-of-service" class="footer-nav__link">{{ 'footer.terms' | t }}</a>
        </nav>

        <details class="footer-accordion footer-accordion--mobile">
          <summary class="footer-accordion__summary">
            <span class="footer-link-group__title">{{ 'navigation.shop' | t }}</span>
            <svg class="footer-accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="footer-link-group__links">
            <a href="{{ public_shop_url }}" class="footer-nav__link">{{ 'navigation.shop' | t }}</a>
            <a href="{{ public_shop_url }}/about" class="footer-nav__link">{{ 'navigation.about' | t }}</a>
            <a href="{{ public_shop_url }}/contact" class="footer-nav__link">{{ 'navigation.contact' | t }}</a>
          </div>
        </details>

        <details class="footer-accordion footer-accordion--mobile">
          <summary class="footer-accordion__summary">
            <span class="footer-link-group__title">{{ 'navigation.services' | t }}</span>
            <svg class="footer-accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="footer-link-group__links">
            <a href="{{ public_storefront_url }}/jamm-cargo" class="footer-nav__link">Jamm Cargo</a>
            <a href="{{ public_storefront_url }}/jamm-fleet" class="footer-nav__link">Jamm Fleet</a>
          </div>
        </details>

        <details class="footer-accordion footer-accordion--mobile">
          <summary class="footer-accordion__summary">
            <span class="footer-link-group__title">{{ 'footer.policies' | t }}</span>
            <svg class="footer-accordion__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="footer-link-group__links">
            <a href="{{ public_shop_url }}/shipping-policy" class="footer-nav__link">{{ 'footer.shipping_policy' | t }}</a>
            <a href="{{ public_shop_url }}/refund-policy" class="footer-nav__link">{{ 'footer.refund_policy' | t }}</a>
            <a href="{{ public_shop_url }}/privacy-policy" class="footer-nav__link">{{ 'footer.privacy_policy' | t }}</a>
            <a href="{{ public_shop_url }}/terms-of-service" class="footer-nav__link">{{ 'footer.terms' | t }}</a>
          </div>
        </details>
      </div>

      <div class="footer-disclaimer">
        <p>
          {{ 'footer.disclaimer' | t }}
        </p>
      </div>

      <div class="footer-bottom">
        <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} Jamm Trade LLC. {{ 'footer.rights' | t }}</p>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
