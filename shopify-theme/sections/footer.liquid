{% assign public_storefront_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' %}
{% assign public_shop_url = public_storefront_url | append: '/shop' %}
{% assign support_email = settings.support_email | default: 'contact@jammtrade.com' %}

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <div class="footer__logo">
          <img class="brand__mark" src="{{ 'logo-badge.png' | asset_url }}" alt="Jamm Trade lotus emblem" width="46" height="46">
          <span class="brand__type">
            <span class="brand__name">JAMM TRADE</span>
            <span class="brand__tag">From Essentials to Enterprise</span>
          </span>
        </div>
        <p class="footer__desc">Rare fragrances and curated essentials for those who know the difference.</p>
        <div class="footer__contact">
          <strong>Jamm Trade LLC</strong>
          <span>Darby, Pennsylvania</span>
          <span>{{ support_email }}</span>
          <span><a href="tel:+14845216277">(484) 521-6277</a></span>
        </div>
      </div>

      <div class="footer__cols">
        <div class="fcol">
          <button class="fcol__head" type="button">Shop <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
          <div class="fcol__list"><div>
            <a href="{{ public_shop_url }}/category/perfumes">Fragrance</a><a href="{{ public_shop_url }}/collection/oud">Oud</a><a href="{{ public_shop_url }}/collection/amber">Amber</a><a href="{{ public_shop_url }}/category/clothing">Clothing</a><a href="{{ public_shop_url }}/category/electronics">Electronics</a><a href="{{ public_shop_url }}/category/health">Health &amp; Wellness</a>
          </div></div>
        </div>
        <div class="fcol">
          <button class="fcol__head" type="button">Services <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
          <div class="fcol__list"><div>
            <a href="{{ public_storefront_url }}/jamm-fleet">Jamm Fleet</a><a href="{{ public_storefront_url }}/jamm-cargo">Jamm Cargo</a><a href="{{ public_shop_url }}/guides">Fragrance Guides</a>
          </div></div>
        </div>
        <div class="fcol">
          <button class="fcol__head" type="button">Policies &amp; Support <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg></button>
          <div class="fcol__list"><div>
            <a href="{{ public_shop_url }}/contact">Contact Support</a><a href="{{ public_shop_url }}/shipping-returns">Shipping &amp; Returns</a><a href="{{ public_shop_url }}/privacy-policy">Privacy Policy</a><a href="{{ public_shop_url }}/terms-of-service">Terms of Service</a><a href="{{ public_shop_url }}/refund-policy">Refund Policy</a>
          </div></div>
        </div>
      </div>
    </div>

    <div class="footer__legal">
      {% comment %} Accepted payment methods, mirroring Shopify checkout's configuration. {% endcomment %}
      <div style="display:flex; flex-wrap:wrap; align-items:center; gap:6px 8px; padding-bottom:4px;">
        <span style="font-family:var(--font-sans); font-size:10px; font-weight:600; letter-spacing:.18em; text-transform:uppercase; color:var(--on-dark-mut);">We accept</span>
        {% assign payment_methods = 'Visa,Mastercard,American Express,Discover,Diners Club,Shop Pay,Apple Pay,Google Pay' | split: ',' %}
        {% for method in payment_methods %}
          <span style="border:1px solid rgba(232,208,154,.25); border-radius:4px; padding:4px 8px; font-family:var(--font-sans); font-size:10px; font-weight:500; color:rgba(239,233,220,.8);">{{ method }}</span>
        {% endfor %}
      </div>
      <p class="footer__disclaimer">Jamm Trade LLC is an independent retailer. We are not officially affiliated with or endorsed by the brands displayed on this site unless explicitly stated. All brand names and trademarks belong to their respective owners.</p>
      <div class="footer__bottom">
        <span class="footer__copy">&copy; 2026 Jamm Trade LLC. All rights reserved.</span>
        <select class="lang-select" aria-label="Language"><option>English</option><option>العربية</option><option>Français</option><option>Español</option></select>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{ "name": "Footer", "settings": [] }
{% endschema %}
