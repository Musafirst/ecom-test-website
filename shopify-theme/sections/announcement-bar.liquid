{% if section.settings.show_announcement %}
<div class="announcement-bar" aria-label="Announcement">
  <div class="announcement-marquee">
    <span class="announcement-track" aria-hidden="false">
      {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- else -%}{{ 'announcement.default' | t }}{%- endif -%}
      {%- if section.settings.text != blank -%}{{ section.settings.text }}{%- else -%}{{ 'announcement.default' | t }}{%- endif -%}
    </span>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text (leave blank to use the translated default)",
      "default": ""
    }
  ]
}
{% endschema %}
