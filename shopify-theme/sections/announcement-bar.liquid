{% if section.settings.show_announcement %}
{% assign items = section.settings.text | split: '·' %}
<div class="announce">
  <div class="announce__track">
    {% for pass in (1..2) %}
      <div class="announce__group"{% if pass == 2 %} aria-hidden="true"{% endif %}>
        {% for item in items %}
          {% assign trimmed = item | strip %}
          {% if trimmed != blank %}
            <span class="announce__item">{{ trimmed }}<span class="dot"></span></span>
          {% endif %}
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text (· separated)",
      "default": "Secure Shopify checkout · Clear shipping options at checkout · Customer support when you need it · Curated products"
    }
  ]
}
{% endschema %}
