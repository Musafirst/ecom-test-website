{% if section.settings.show_announcement %}
<div class="announcement-bar" aria-label="Announcement">
  <div class="announcement-marquee">
    <span class="announcement-track" aria-hidden="false">
      {{ section.settings.text | default: 'announcement.default' | t }}
      {{ section.settings.text | default: 'announcement.default' | t }}
    </span>
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Curated products  -  Secure Shopify checkout  -  Clear shipping options at checkout  -  Customer support when you need it  -"
    }
  ]
}
{% endschema %}
