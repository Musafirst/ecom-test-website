<section class="trust-bar-section">
  <div class="container">
    <div class="trust-bar">
      <div class="beam beam--xl beam--d2" aria-hidden="true"></div>
      {% for block in section.blocks %}
        {% if block.type == 'trust_item' %}
        <div class="trust-item" {{ block.shopify_attributes }}>
          <div class="trust-item__icon">
            {% case block.settings.icon %}
              {% when 'star' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4L12 14.4l-4.8 2.5.9-5.4L4.2 7.7l5.4-.8z" stroke-linejoin="round"/></svg>
              {% when 'globe' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M2 12h20M12 3a15.3 15.3 0 010 18M12 3a15.3 15.3 0 000 18" stroke-linecap="round"/></svg>
              {% when 'check' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>
              {% when 'lock' %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4" stroke-linecap="round"/></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="12" r="10"/></svg>
            {% endcase %}
          </div>
          <div class="trust-item__text">
            <h4 class="trust-item__label">{{ block.settings.label }}</h4>
            <p class="trust-item__detail">{{ block.settings.detail }}</p>
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "star", "label": "Star" }, { "value": "globe", "label": "Globe" }, { "value": "check", "label": "Check" }, { "value": "lock", "label": "Lock" }], "default": "check" },
        { "type": "text", "id": "label", "label": "Label", "default": "Authentic Products" },
        { "type": "text", "id": "detail", "label": "Detail", "default": "Every item sourced and verified." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "star", "label": "Authentic Products", "detail": "Every item sourced and verified." } },
        { "type": "trust_item", "settings": { "icon": "globe", "label": "Reliable Shipping", "detail": "Clear delivery options at checkout." } },
        { "type": "trust_item", "settings": { "icon": "check", "label": "Premium Quality", "detail": "Curated with intention." } },
        { "type": "trust_item", "settings": { "icon": "lock", "label": "Secure Checkout", "detail": "Your data, protected." } }
      ]
    }
  ]
}
{% endschema %}
