{% assign public_storefront_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' %}
{% assign public_shop_url = public_storefront_url | append: '/shop' %}

<section class="hero-wrap" id="ecosystem">
  <div class="container">
    <div class="hero">
      <div class="hero__stage">
        <div class="hero__media">
          <div class="hero__media-inner">
            <video class="hero__video" src="{{ 'jamm-trade-cinematic-hero.mp4' | asset_url }}" poster="{{ 'jamm-trade-ecosystem-poster-1600.jpg' | asset_url }}" autoplay muted loop playsinline preload="auto"></video>
          </div>
        </div>

        <article class="slide slide--clothing is-active">
          <div class="slide__bg"><div class="slide__glow"></div></div>
          <div class="slide__frame"></div>
          <div class="slide__content">
            <p class="slide__eyebrow">Clothing</p>
            <h2 class="slide__title">Wear the <em>mark.</em></h2>
            <p class="slide__sub">Hoodies, tees and everyday essentials carrying the Jamm Trade lotus — quiet, considered, unmistakable.</p>
            <div class="slide__cta"><a class="btn btn--gold" href="{{ public_shop_url }}/collection/clothing">Shop Clothing</a></div>
          </div>
        </article>

        <article class="slide slide--fragrance">
          <div class="slide__bg"><div class="slide__glow"></div></div>
          <div class="slide__frame"></div>
          <div class="slide__content">
            <p class="slide__eyebrow">Signature Scents</p>
            <h2 class="slide__title">Scents that <em>linger.</em></h2>
            <p class="slide__sub">Rare Arabic oud, warm amber and clean daily signatures — curated for those who know the difference.</p>
            <div class="slide__cta"><a class="btn btn--gold" href="{{ public_shop_url }}/category/perfumes">Shop Fragrance</a></div>
          </div>
        </article>

        <article class="slide slide--audio">
          <div class="slide__bg"><div class="slide__glow"></div></div>
          <div class="slide__frame"></div>
          <div class="slide__content">
            <p class="slide__eyebrow">Electronics</p>
            <h2 class="slide__title">Sound, <em>refined.</em></h2>
            <p class="slide__sub">Premium audio and everyday technology, chosen with the same eye for quality and focus.</p>
            <div class="slide__cta"><a class="btn btn--gold" href="{{ public_shop_url }}/category/electronics">Shop Electronics</a></div>
          </div>
        </article>

        <article class="slide slide--house">
          <div class="slide__bg"><div class="slide__glow"></div></div>
          <div class="slide__frame"></div>
          <div class="slide__content">
            <p class="slide__eyebrow">The House of Jamm</p>
            <h2 class="slide__title">From essentials<br>to <em>enterprise.</em></h2>
            <p class="slide__sub">One trusted name across every category we touch — fragrance, apparel, electronics and the fleet that moves them.</p>
            <div class="slide__cta"><a class="btn btn--gold" href="{{ public_shop_url }}">Explore the House</a></div>
          </div>
        </article>

        <article class="slide slide--eco">
          <div class="eco-stage">
            <a class="hotspot" href="{{ public_storefront_url }}/jamm-fleet" style="left:23.5%; top:43%" aria-label="Jamm Fleet">
              <span class="hotspot__pulse"></span><span class="hotspot__ring"></span><span class="hotspot__label"><b>Jamm Fleet&nbsp;&rarr;</b></span>
            </a>
            <a class="hotspot" href="{{ public_storefront_url }}/jamm-cargo" style="left:58%; top:33%" aria-label="Jamm Cargo">
              <span class="hotspot__pulse"></span><span class="hotspot__ring"></span><span class="hotspot__label"><b>Jamm Cargo&nbsp;&rarr;</b></span>
            </a>
            <a class="hotspot" href="{{ public_shop_url }}/category/perfumes" style="left:30%; top:71%" aria-label="Fragrance collection">
              <span class="hotspot__pulse"></span><span class="hotspot__ring"></span><span class="hotspot__label"><b>Fragrance&nbsp;&rarr;</b></span>
            </a>
            <a class="hotspot" href="{{ public_shop_url }}/category/electronics" style="left:64%; top:72%" aria-label="Electronics collection">
              <span class="hotspot__pulse"></span><span class="hotspot__ring"></span><span class="hotspot__label"><b>Electronics&nbsp;&rarr;</b></span>
            </a>
            <a class="hotspot" href="{{ public_shop_url }}/collection/clothing" style="left:86%; top:46%" aria-label="Apparel collection">
              <span class="hotspot__pulse"></span><span class="hotspot__ring"></span><span class="hotspot__label"><b>Apparel&nbsp;&rarr;</b></span>
            </a>
          </div>
          <div class="eco-caption">
            <p class="slide__eyebrow">The Jamm Ecosystem</p>
            <h2 class="eco-caption__title">One house. Every essential.</h2>
            <p class="eco-caption__hint"><span class="pulse-dot"></span> Tap a point to explore</p>
          </div>
        </article>

        <button class="hero__arrow hero__arrow--prev" aria-label="Previous slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 5l-7 7 7 7"/></svg>
        </button>
        <button class="hero__arrow hero__arrow--next" aria-label="Next slide">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
        </button>
        <div class="hero__dots">
          <button class="dot is-active" aria-label="Slide 1"></button>
          <button class="dot" aria-label="Slide 2"></button>
          <button class="dot" aria-label="Slide 3"></button>
          <button class="dot" aria-label="Slide 4"></button>
          <button class="dot" aria-label="Slide 5"></button>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Slideshow",
  "settings": []
}
{% endschema %}
