{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}

<section class="section" id="collections" style="padding-top:0">
  <div class="container">
    <div class="section-head">
      <div class="head-left reveal">
        <p class="eyebrow">Collections</p>
        <h2 class="section-title">Shop by scent family</h2>
        <p class="section-sub">Choose by mood first, then explore the products inside each edit.</p>
      </div>
      <div class="rule"></div>
    </div>

    <div class="collections">
      <article class="collection reveal">
        <div class="collection__inner">
          <div class="collection__media-fallback" style="background:radial-gradient(110% 90% at 70% 8%,#3a2b1c,#1c150d 58%,#0c0907)"></div>
          <img src="{{ 'logo-gold.png' | asset_url }}" alt="" class="slide__lotus" width="420" height="420" style="opacity:.08; right:-8%; bottom:-10%; width:70%">
          <span class="collection__tab">Oud</span>
          <div class="collection__content">
            <span class="collection__count">{{ collections.oud.products_count | default: 6 }} Fragrances</span>
            <h3 class="collection__name">Oud</h3>
            <p class="collection__desc">Resinous, dark, and long lasting.</p>
            <a class="btn btn--ghost" href="{{ public_shop_url }}/collection/oud">Explore</a>
          </div>
        </div>
      </article>

      <article class="collection reveal">
        <div class="collection__inner">
          <div class="collection__media-fallback" style="background:radial-gradient(110% 90% at 70% 8%,#4a3a1e,#241a0d 58%,#0d0a06)"></div>
          <img src="{{ 'logo-gold.png' | asset_url }}" alt="" class="slide__lotus" width="420" height="420" style="opacity:.08; right:-8%; bottom:-10%; width:70%">
          <span class="collection__tab">Amber</span>
          <div class="collection__content">
            <span class="collection__count">{{ collections.amber.products_count | default: 6 }} Fragrances</span>
            <h3 class="collection__name">Amber</h3>
            <p class="collection__desc">Warm vanilla, soft spice, skin-close depth.</p>
            <a class="btn btn--ghost" href="{{ public_shop_url }}/collection/amber">Explore</a>
          </div>
        </div>
      </article>

      <article class="collection reveal">
        <div class="collection__inner">
          <div class="collection__media-fallback" style="background:radial-gradient(110% 90% at 70% 8%,#2f3230,#181917 58%,#0a0b0a)"></div>
          <img src="{{ 'logo-gold.png' | asset_url }}" alt="" class="slide__lotus" width="420" height="420" style="opacity:.07; right:-8%; bottom:-10%; width:70%">
          <span class="collection__tab">Daily</span>
          <div class="collection__content">
            <span class="collection__count">{{ collections.daily.products_count | default: 4 }} Fragrances</span>
            <h3 class="collection__name">Daily</h3>
            <p class="collection__desc">Clean signatures for repeat wear.</p>
            <a class="btn btn--ghost" href="{{ public_shop_url }}/collection/daily">Explore</a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Collection Grid", "settings": [] }
{% endschema %}
