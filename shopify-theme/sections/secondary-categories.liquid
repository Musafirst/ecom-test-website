{% assign public_shop_url = settings.public_storefront_url | default: 'https://www.jammtrade.com' | append: '/shop' %}

<section class="section" id="beyond" style="padding-top:0">
  <div class="container">
    <div class="section-head">
      <div class="head-left reveal">
        <p class="eyebrow">Also Available</p>
        <h2 class="section-title">Beyond fragrance</h2>
        <p class="section-sub">A small selection of essentials that fits the same curated standard.</p>
      </div>
      <div class="rule"></div>
    </div>

    <div class="beyond">
      <article class="collection reveal">
        <div class="collection__inner">
          <div class="collection__img"><img src="https://cdn.shopify.com/s/files/1/0795/9379/9907/files/unisex-heavyweight-hooded-sweatshirt-black-front-6a18dc6bbde52.jpg?v=1780014207" alt="Jamm Trade Heritage Hoodie" width="1200" height="1400" loading="lazy"></div>
          <span class="collection__tab">Clothing</span>
          <div class="collection__content">
            <span class="collection__count">Wear the mark.</span>
            <h3 class="collection__name">Clothing</h3>
            <p class="collection__desc">Hoodies, tees, and essentials with the Jamm Trade lotus mark.</p>
            <a class="btn btn--ghost" href="{{ public_shop_url }}/category/clothing">Shop Clothing</a>
          </div>
        </div>
      </article>

      <article class="collection reveal">
        <div class="collection__inner">
          <div class="collection__img"><img src="https://cdn.shopify.com/s/files/1/0795/9379/9907/files/6c64ba8bb8e9c9b48f05aa6bc781d8f4a4aaeaf837568040ae191a5112c5343a.jpg?v=1779056822" alt="Premium audio and electronics" width="1200" height="1400" loading="lazy"></div>
          <span class="collection__tab">Electronics</span>
          <div class="collection__content">
            <span class="collection__count">Precision essentials.</span>
            <h3 class="collection__name">Electronics</h3>
            <p class="collection__desc">Premium audio and everyday electronics selected for quality and focus.</p>
            <a class="btn btn--ghost" href="{{ public_shop_url }}/category/electronics">Shop Electronics</a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Secondary Categories", "settings": [] }
{% endschema %}
